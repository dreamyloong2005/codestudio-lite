{
  "name": "codestudio-lite",
  "private": true,
  "version": "1.5.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "vite build",
    "prepare": "panda codegen",
    "panda:codegen": "panda codegen",
    "panda:watch": "panda codegen --watch",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "updater:config": "node scripts/prepare-updater-config.mjs",
    "updater:manifest": "node scripts/generate-update-manifest.mjs",
    "updater:publish": "node scripts/publish-update-r2.mjs",
    "updater:key:init": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/setup-updater-signing-key.ps1",
    "updater:key:export": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/export-updater-signing-key.ps1",
    "updater:key:import": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/import-updater-signing-key.ps1",
    "tauri:build:updater": "npm run updater:config && tauri build --config src-tauri/tauri.updater.generated.conf.json",
    "updater:build:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/windows/burn/build-burn.ps1 -RequireUpdater",
    "updater:build:macos": "bash scripts/build-macos-updater.sh",
    "updater:build:linux": "bash scripts/build-linux-updater.sh",
    "normalize:linux": "bash scripts/normalize-linux-artifacts.sh",
    "tauri:build:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File installer/windows/burn/build-burn.ps1",
    "tauri:build:dmg": "scripts/build-macos-dmg.sh",
    "tauri:sign:macos": "scripts/sign-macos-bundle.sh",
    "icons": "tauri icon public/icon.png && node scripts/sharpen-small-icons.mjs",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "test:unit": "tsc -p tsconfig.tests.json && node --test src/lib/*.test.mjs",
    "test": "npm run check && npm run test:unit"
  },
  "dependencies": {
    "@iconify-icons/ph": "^1.2.5",
    "@iconify/svelte": "^5.2.2",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "svelte": "^5.0.0",
    "svelte-dnd-action": "^0.9.70"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.11.3",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tauri-apps/cli": "^2.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "postcss": "^8.5.15",
    "sharp": "^0.35.2",
    "svelte-check": "^4.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.3.0"
  }
}
